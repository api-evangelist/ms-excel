  "info": {
    "_postman_id": "51d059fa-ad39-4da3-910e-075cac7e20fd",
    "name": "Microsoft Graph Excel API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Microsoft Graph REST API for reading and modifying Excel workbooks stored in\nOneDrive for Business, SharePoint, or Group drives. Supports worksheets,\ntables, charts, ranges, named items, and workbook functions. Authentication\nuses the Microsoft identity platform (OAuth 2.0) with a bearer access token.\nRequires Files.Read or Files.ReadWrite permission scopes.\n\n\nContact Support:\n Name: Microsoft Graph",
      "type": "text/plain"
    }
  }
